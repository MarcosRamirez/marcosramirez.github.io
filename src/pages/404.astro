---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="404 - Página no encontrada"
  keywords="404,error,pagina no encontrada"
  description="Página no encontrada - Error 404"
>
  <section>
    <h1>> ERROR_404</h1>

    <p class="prompt">Página no encontrada...</p>

    <p>
      <span class="prompt">></span> El recurso solicitado no existe o ha sido movido.
    </p>
    
    <p>
      <span class="prompt">></span> Possibles causas:
    </p>
    <ul class="reasons">
      <li>> La URL está mal escrita</li>
      <li>> El recurso fue eliminado</li>
      <li>> Estás intentando acceder a un sistema operativo de los 90 sin tener permisos de root</li>
    </ul>
    
    <p class="prompt">> Volver al <a href="/" class="highlight">inicio</a> <span class="blink">_</span></p>
  </section>
</Layout>

<style>
  .reasons {
    list-style: none;
    padding: 0;
    margin: 1rem 0;
  }
  
  .reasons li {
    margin: 8px 0;
    line-height: 1.6;
  }
  
  .highlight {
    color: #33ff33;
    font-weight: bold;
    text-decoration: none;
  }
  
  .highlight:hover {
    background: #33ff33;
    color: #000;
  }
</style>