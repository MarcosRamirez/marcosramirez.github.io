---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Marcos Ramírez" description="Web personal" keywords="Marcos Ramirez">
  <div id="terminal"></div>
</Layout>

<script>
  const lines = [
    'Initializing system...',
    'Loading modules...',
    'Checking network...',
    'Connecting to database...',
    'Ready.',
    '',
    '╔═══════════════════════════════════════╗',
    '║         MARCOS RAMÍREZ v1.0           ║',
    '╚═══════════════════════════════════════╝',
    '',
    '> Occupation: Software Engineer',
    '> Location: Spain',
    '> Status: Online',
    '',
    'Bienvenido a mi dominio personal.',
    'Usa el menú de arriba para navegar.',
    '',
    '> Esperando comando...'
  ];

  const terminal = document.getElementById('terminal');
  let lineIndex = 0;
  let charIndex = 0;
  
  // Crear cursor una sola vez y reutilizarlo
  const cursor = document.createElement('span');
  cursor.className = 'cursor';
  cursor.textContent = '▋';
  terminal.appendChild(cursor);

  function typeChar() {
    if (lineIndex >= 5) {
      cursor.style.display = 'none';
      typeLine();
      return;
    }
    
    const line = lines[lineIndex];
    
    if (charIndex === 0) {
      const p = document.createElement('p');
      if (line.startsWith('>') || line.startsWith('╔') || line.startsWith('╚')) {
        p.className = 'prompt';
      }
      terminal.insertBefore(p, cursor);
    }
    
    const currentP = terminal.querySelector('p:last-of-type');
    
    if (line === '') {
      currentP.innerHTML = '&nbsp;';
      lineIndex++;
      charIndex = 0;
      setTimeout(typeChar, 150);
    } else if (charIndex < line.length) {
      currentP.textContent = line.substring(0, charIndex + 1);
      cursor.style.display = 'inline';
      charIndex++;
      setTimeout(typeChar, 30 + Math.random() * 40);
    } else {
      lineIndex++;
      charIndex = 0;
      setTimeout(typeChar, 200);
    }
  }
  
  function typeLine() {
    if (lineIndex >= lines.length) {
      cursor.textContent = '_';
      cursor.style.display = 'inline';
      cursor.classList.add('blink');
      return;
    }
    
    const line = lines[lineIndex];
    const p = document.createElement('p');
    p.textContent = line;
    if (line.startsWith('>') || line.startsWith('╔') || line.startsWith('╚')) {
      p.className = 'prompt';
    }
    if (line === '') {
      p.innerHTML = '&nbsp;';
    }
    terminal.insertBefore(p, cursor);
    
    lineIndex++;
    setTimeout(typeLine, 150);
  }

  // Ocultar cursor inicialmente
  cursor.style.display = 'none';
  setTimeout(typeChar, 500);
</script>

<style>
  #terminal {
    min-height: 300px;
  }
  
  .cursor {
    color: #33ff33;
    font-weight: bold;
  }
  
  .blink {
    animation: blink 1s step-end infinite;
  }
  
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
</style>