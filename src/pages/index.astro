---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Marcos Ramírez" description="Web personal" keywords="Marcos Ramirez">
  <div id="terminal"></div>
</Layout>

<script>
  const lines = [
    'Initializing system...',
    'Loading modules...',
    'Checking network...',
    'Connecting to database...',
    'Ready.',
    '',
    '╔═══════════════════════════════════════╗',
    '║         MARCOS RAMÍREZ v1.0           ║',
    '╚═══════════════════════════════════════╝',
    '',
    '> Occupation: Software Engineer',
    '> Location: Spain',
    '> Status: Online',
    '',
    'Bienvenido a mi dominio personal.',
    'Usa el menú de arriba para navegar.',
    '',
    '> Esperando comando...'
  ];

  const terminal = document.getElementById('terminal');
  let lineIndex = 0;
  let charIndex = 0;
  let cursor;
  
  function createCursor() {
    cursor = document.createElement('span');
    cursor.className = 'cursor blink';
    return cursor;
  }
  
  function removeCursor() {
    if (cursor && cursor.parentNode) {
      cursor.remove();
    }
  }

  function typeChar() {
    if (lineIndex >= 5) {
      removeCursor();
      typeLine();
      return;
    }
    
    const line = lines[lineIndex];
    
    if (charIndex === 0) {
      const p = document.createElement('p');
      if (line.startsWith('>') || line.startsWith('╔') || line.startsWith('║') || line.startsWith('╚')) {
        p.className = 'prompt';
      }
      terminal.appendChild(p);
      terminal.appendChild(createCursor());
    }
    
    const currentP = terminal.querySelector('p:last-of-type');
    removeCursor();
    
    if (line === '') {
      currentP.innerHTML = '&nbsp;';
      terminal.appendChild(createCursor());
      lineIndex++;
      charIndex = 0;
      setTimeout(typeChar, 150);
    } else if (charIndex < line.length) {
      currentP.textContent = line.substring(0, charIndex + 1);
      charIndex++;
      terminal.appendChild(createCursor());
      setTimeout(typeChar, 30 + Math.random() * 40);
    } else {
      lineIndex++;
      charIndex = 0;
      setTimeout(typeChar, 200);
    }
  }
  
  function typeLine() {
    if (lineIndex >= lines.length) {
      const finalCursor = document.createElement('span');
      finalCursor.className = 'cursor blink';
      terminal.appendChild(finalCursor);
      return;
    }
    
    const line = lines[lineIndex];
    const p = document.createElement('p');
    p.textContent = line;
    if (line.startsWith('>') || line.startsWith('╔') || line.startsWith('║') || line.startsWith('╚')) {
      p.className = 'prompt';
    }
    if (line === '') {
      p.innerHTML = '&nbsp;';
    }
    terminal.appendChild(p);
    
    lineIndex++;
    setTimeout(typeLine, 150);
  }

  setTimeout(typeChar, 500);
</script>

<style>
  .cursor {
    display: inline-block;
  }
  
  .blink {
    animation: blink 1s step-end infinite;
  }
  
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
</style>