---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Marcos Ramírez" description="Web personal" keywords="Marcos Ramirez">
  <div id="terminal"></div>
</Layout>

<script>
  const lines = [
    'Initializing system...',
    'Loading modules...',
    'Checking network...',
    'Connecting to database...',
    'Ready.',
    '',
    '╔═══════════════════════════════════════╗',
    '║         MARCOS RAMÍREZ v1.0           ║',
    '╚═══════════════════════════════════════╝',
    '',
    '> Occupation: Software Engineer',
    '> Location: Spain',
    '> Status: Online',
    '',
    'Bienvenido a mi dominio personal.',
    'Usa el menú de arriba para navegar.',
    '',
    '> Esperando comando...'
  ];

  const terminal = document.getElementById('terminal');
  let lineIndex = 0;
  let charIndex = 0;
  let currentLine = '';
  
  function typeChar() {
    if (lineIndex >= lines.length) {
      const cursor = document.createElement('span');
      cursor.className = 'cursor blink';
      terminal.appendChild(cursor);
      return;
    }
    
    const line = lines[lineIndex];
    
    if (charIndex === 0) {
      const p = document.createElement('p');
      if (line.startsWith('>') || line.startsWith('╔') || line.startsWith('║') || line.startsWith('╚')) {
        p.className = 'prompt';
      }
      if (line === '') {
        p.innerHTML = '&nbsp;';
      }
      terminal.appendChild(p);
      currentLine = line;
    }
    
    const currentP = terminal.lastElementChild;
    
    if (line === '') {
      lineIndex++;
      charIndex = 0;
      setTimeout(typeChar, 150);
    } else if (charIndex < line.length) {
      currentP.textContent = line.substring(0, charIndex + 1);
      charIndex++;
      setTimeout(typeChar, 30 + Math.random() * 30);
    } else {
      lineIndex++;
      charIndex = 0;
      setTimeout(typeChar, 200);
    }
  }

  setTimeout(typeChar, 500);
</script>

<style>
  .cursor {
    display: inline-block;
  }
  
  .blink {
    animation: blink 1s step-end infinite;
  }
  
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
</style>