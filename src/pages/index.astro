---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Marcos Ramírez" description="Web personal" keywords="Marcos Ramirez">
  <div id="terminal"></div>
</Layout>

<script>
  const lines = [
    'Initializing system...',
    'Loading modules...',
    'Checking network...',
    'Connecting to database...',
    '> Ready.',
    '',
    '╔════════════════════════════════╗',
    '║  MARCOS RAMÍREZ v0.1a         ║',
    '╚════════════════════════════════╝',
    '',
    '> Occupation: Software Engineer',
    '> Location: Spain',
    '> Status: Online',
    '',
    'Este es mi dominio personal, aquí encontrarás un poco de todo.',
    '',
    'Si quieres saber más sobre el Marcos Ramírez programador/ingeniero:',
    '> [SOBRE_MI]',
    '',
    'Si quieres saber sobre mí a título más personal:',
    '> [SOBRE_MI] (al final de la página)',
    '',
    'El motivo de existir de esta página es que desde hace un tiempo,',
    'me dedico a intentar posicionar en Google mejor que mis tocayos:',
    '',
    '> Marcos Ramírez (el de las motos)',
    '> Marcos Ramírez (el de YouTube clickbait)',
    '> Marcos Ramírez (el protagonista de la novela)',
    '',
    'Así que, aquí podrás encontrar enlaces a mis redes sociales,',
    'y por ejemplo, una lista de cosas que me puedes regalar:',
    '> [CUMPLE] (regalos para mi cumpleaños)',
    '',
    'También puedes descargar mi Curriculum:',
    '> [MI_CV] (en Word, PDF, etc...)',
    '',
    'Usa el menú de arriba para navegar.',
    '',
    '> Esperando comando...'
  ];

  const terminal = document.getElementById('terminal');
  let lineIndex = 0;
  let charIndex = 0;
  let currentP;
  
  const cursor = document.createElement('span');
  cursor.className = 'cursor';
  cursor.textContent = '▋';

  function typeChar() {
    if (lineIndex >= 5) {
      if (currentP && currentP.contains(cursor)) {
        currentP.removeChild(cursor);
      }
      typeLine();
      return;
    }
    
    const line = lines[lineIndex];
    
    if (charIndex === 0) {
      currentP = document.createElement('p');
      if (line.startsWith('>') || line.startsWith('╔') || line.startsWith('╚')) {
        currentP.className = 'prompt';
      }
      currentP.appendChild(cursor);
      terminal.appendChild(currentP);
    }
    
    if (line === '') {
      currentP.innerHTML = '&nbsp;';
      lineIndex++;
      charIndex = 0;
      setTimeout(typeChar, 150);
    } else if (charIndex < line.length) {
      // Solo actualizar el texto, no tocar el cursor que ya está dentro
      const textSpan = document.createElement('span');
      textSpan.className = 'typing-text';
      textSpan.textContent = line.substring(0, charIndex + 1);
      
      // Reconstruir contenido: texto + cursor
      currentP.innerHTML = '';
      currentP.appendChild(textSpan);
      currentP.appendChild(cursor);
      
      charIndex++;
      setTimeout(typeChar, 30 + Math.random() * 40);
    } else {
      lineIndex++;
      charIndex = 0;
      setTimeout(typeChar, 200);
    }
  }
  
  function typeLine() {
    if (lineIndex >= lines.length) {
      cursor.textContent = '_';
      cursor.classList.add('blink');
      terminal.appendChild(cursor);
      return;
    }
    
    const line = lines[lineIndex];
    const p = document.createElement('p');
    
    // Convertir [ENLACE] en enlaces clickables
    let processedLine = line;
    if (line.includes('[')) {
      processedLine = line
        .replace(/\[SOBRE_MI\]/g, '<a href="/sobre-mi" class="link">[SOBRE_MI]</a>')
        .replace(/\[CUMPLE\]/g, '<a href="/cumpleanos" class="link">[CUMPLE]</a>')
        .replace(/\[MI_CV\]/g, '<a href="https://linkedin.com/in/marcosramirez" target="_blank" class="link">[MI_CV]</a>');
      p.innerHTML = processedLine;
    } else {
      p.textContent = line;
    }
    
    if (line.startsWith('>') || line.startsWith('╔') || line.startsWith('╚')) {
      p.className = 'prompt';
    }
    if (line === '') {
      p.innerHTML = '&nbsp;';
    }
    terminal.appendChild(p);
    
    lineIndex++;
    setTimeout(typeLine, 150);
  }

  setTimeout(typeChar, 500);
</script>

<style>
  #terminal {
    min-height: 300px;
  }
  
  .cursor {
    color: #33ff33;
    font-weight: bold;
    display: inline;
  }
  
  .blink {
    animation: blink 1s step-end infinite;
  }
  
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
  
  #terminal .link {
    color: #33ff33;
    text-decoration: none;
  }
  
  #terminal .link:hover {
    background: #33ff33;
    color: #000;
  }
</style>