---
const pathname = Astro.url.pathname;
---

<header>
  <div class="navbar">
    <a href="/" class="brand">
      <span class="glitch" data-text="MARCOS_RAMIREZ v1.0.1">MARCOS_RAMIREZ v1.0.1</span>
    </a>
    <input type="checkbox" id="menu-toggle" class="menu-toggle">
    <label for="menu-toggle" class="menu-icon" aria-label="Abrir menú">[MENU]</label>
    <nav id="nav-menu" class="nav-menu">
      <a href="/" class:list={{ active: pathname === '/' }} aria-current={pathname === '/' ? 'page' : undefined}>[HOME]</a>
      <a href="/sobre-mi" class:list={{ active: pathname.startsWith('/sobre-mi') }} aria-current={pathname.startsWith('/sobre-mi') ? 'page' : undefined}>[SOBRE_MI]</a>
      <a href="/contacto" class:list={{ active: pathname.startsWith('/contacto') }} aria-current={pathname.startsWith('/contacto') ? 'page' : undefined}>[CONTACTO]</a>
      <a href="/novela-carlos-luis-fallas" class:list={{ active: pathname.startsWith('/novela-carlos-luis-fallas') }} aria-current={pathname.startsWith('/novela-carlos-luis-fallas') ? 'page' : undefined}>[NOVELA]</a>
      <a href="/cumpleanos" class:list={{ active: pathname.startsWith('/cumpleanos') }} aria-current={pathname.startsWith('/cumpleanos') ? 'page' : undefined}>[CUMPLE]</a>
      <a href="https://blog.marcosramirez.info" target="_blank">[BLOG]</a>
      <a href="https://github.com/MarcosRamirez" target="_blank">[GITHUB]</a>
    </nav>
  </div>
</header>

<style>
  .navbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    padding: 0 20px;
  }

  @media (min-width: 769px) {
    .navbar nav {
      display: flex;
      gap: 15px;
    }
  }

  .navbar a {
    border: none;
    text-decoration: none;
    color: #33ff33;
    transition: all 0.2s;
    text-shadow: 0 0 5px rgba(51, 255, 51, 0.5);
  }

  .navbar a:hover {
    background: #33ff33;
    color: #050505;
    text-shadow: none;
  }

  .navbar a[aria-current="page"] {
    background: #33ff33;
    color: #050505;
    text-shadow: none;
  }

  .brand {
    font-size: 1.3rem;
    letter-spacing: 2px;
  }

  .glitch {
    position: relative;
    display: inline-block;
  }

  .glitch::before,
  .glitch::after {
    content: attr(data-text);
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .glitch::before {
    animation: glitch-1 3s infinite linear alternate-reverse;
    clip-path: polygon(0 0, 100% 0, 100% 35%, 0 35%);
    color: #ff00ff;
    z-index: -1;
  }

  .glitch::after {
    animation: glitch-2 2s infinite linear alternate-reverse;
    clip-path: polygon(0 65%, 100% 65%, 100% 100%, 0 100%);
    color: #00ffff;
    z-index: -2;
  }

  @keyframes glitch-1 {
    0% { transform: translate(0); }
    20% { transform: translate(-2px, 2px); }
    40% { transform: translate(-2px, -2px); }
    60% { transform: translate(2px, 2px); }
    80% { transform: translate(2px, -2px); }
    100% { transform: translate(0); }
  }

  @keyframes glitch-2 {
    0% { transform: translate(0); }
    20% { transform: translate(2px, -2px); }
    40% { transform: translate(2px, 2px); }
    60% { transform: translate(-2px, -2px); }
    80% { transform: translate(-2px, 2px); }
    100% { transform: translate(0); }
  }

  .menu-icon {
    display: none;
    cursor: pointer;
    font-size: 1rem;
    color: #33ff33;
  }

  .menu-toggle {
    display: none;
  }

  @media (max-width: 768px) {
    .navbar {
      flex-wrap: wrap;
      position: relative;
    }

    .nav-menu {
      display: none;
      flex-direction: column;
      width: 100%;
      position: absolute;
      top: 60px;
      left: 0;
      z-index: 1000;
      padding: 20px;
      border: 1px dashed #33ff33;
      background: #050505;
    }

    .menu-icon {
      display: block;
    }
  }

  @media (max-width: 480px) {
    .navbar a {
      font-size: 14px;
    }
    .brand {
      font-size: 1rem;
    }
  }
</style>

<style is:global>
  @media (max-width: 768px) {
    #menu-toggle:checked ~ #nav-menu {
      display: flex;
    }
  }
</style>