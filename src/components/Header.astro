---
const pathname = Astro.url.pathname;
---

<header>
  <div class="navbar">
    <a href="/" class="brand">MARCOS_RAMIREZ v0.1a</a>
    <input type="checkbox" id="menu-toggle" class="menu-toggle">
    <label for="menu-toggle" class="menu-icon">[MENU]</label>
    <nav class="nav-menu">
      <a href="/" class:list={{ active: pathname === '/' }} aria-current={pathname === '/' ? 'page' : undefined}>[HOME]</a>
      <a href="/sobre-mi" class:list={{ active: pathname.startsWith('/sobre-mi') }} aria-current={pathname.startsWith('/sobre-mi') ? 'page' : undefined}>[SOBRE_MI]</a>
      <a href="/contacto" class:list={{ active: pathname.startsWith('/contacto') }} aria-current={pathname.startsWith('/contacto') ? 'page' : undefined}>[CONTACTO]</a>
      <a href="/marcos-ramirez-la-novela" class:list={{ active: pathname.startsWith('/marcos-ramirez-la-novela') }} aria-current={pathname.startsWith('/marcos-ramirez-la-novela') ? 'page' : undefined}>[NOVELA]</a> 
      <a href="/cumpleanos" class:list={{ active: pathname.startsWith('/cumpleanos') }} aria-current={pathname.startsWith('/cumpleanos') ? 'page' : undefined}>[CUMPLE]</a>
      <a href="https://blog.marcosramirez.info" target="_blank">[BLOG]</a> 
      <a href="https://github.com/MarcosRamirez" target="_blank">[GITHUB]</a>
    </nav>
  </div>
</header>

<style>
  .navbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    padding: 0 20px;
  }

  .navbar nav {
    display: flex;
    gap: 15px;
  }

  .navbar a {
    border: none;
    text-decoration: none;
    color: #33ff33;
    transition: all 0.2s;
  }

  .navbar a:hover {
    background: #33ff33;
    color: #000;
  }

  .navbar a[aria-current="page"] {
    background: #33ff33;
    color: #000;
  }

  .brand {
    font-size: 1.3rem;
    letter-spacing: 2px;
  }

  .menu-icon {
    display: none;
    cursor: pointer;
    font-size: 1rem;
  }

  .menu-toggle {
    display: none;
  }

  @media (max-width: 768px) {
    .navbar {
      flex-wrap: wrap;
    }

    .nav-menu {
      display: none;
      flex-direction: column;
      width: 100%;
      position: absolute;
      top: 60px;
      left: 0;
      padding: 20px;
      border: 1px dashed #33ff33;
      background: #0a0a0a;
    }

    .menu-icon {
      display: block;
    }

    #menu-toggle:checked ~ .nav-menu {
      display: flex;
    }
  }
  
  @media (max-width: 480px) {
    .navbar a {
      font-size: 14px;
    }
    .brand {
      font-size: 1rem;
    }
  }
</style>