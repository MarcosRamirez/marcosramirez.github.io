<header>
  <div class="navbar">
    <a href="/" class="brand">MARCOS_RAMIREZ</a>
    <input type="checkbox" id="menu-toggle" class="menu-toggle">
    <label for="menu-toggle" class="menu-icon">[MENU]</label>
    <nav class="nav-menu">
      <a href="/sobre-mi">[SOBRE_MI]</a>
      <a href="/contacto">[CONTACTO]</a>
      <a href="https://blog.marcosramirez.info" target="_blank">[BLOG]</a> 
      <a href="https://github.com/MarcosRamirez" target="_blank">[GITHUB]</a>
      <a href="/marcos-ramirez-la-novela">[NOVELA]</a> 
    </nav>
  </div>
</header>

<style>
  .navbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    padding: 0 20px;
  }

  .navbar nav {
    display: flex;
    gap: 15px;
  }

  .navbar a {
    border: none;
    text-decoration: none;
    color: #33ff33;
  }

  .navbar a:hover {
    background: transparent;
    color: #1a8c1a;
    text-shadow: 0 0 10px #33ff33;
  }

  .brand {
    font-size: 1.3rem;
    letter-spacing: 2px;
  }

  .menu-icon {
    display: none;
    cursor: pointer;
    font-size: 1rem;
  }

  .menu-toggle {
    display: none;
  }

  @media (max-width: 768px) {
    .navbar {
      flex-wrap: wrap;
    }

    .nav-menu {
      display: none;
      flex-direction: column;
      width: 100%;
      position: absolute;
      top: 60px;
      left: 0;
      padding: 20px;
      border: 1px dashed #33ff33;
      background: #0a0a0a;
    }

    .menu-icon {
      display: block;
    }

    #menu-toggle:checked ~ .nav-menu {
      display: flex;
    }
  }
</style>