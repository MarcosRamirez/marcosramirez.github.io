---
---

<footer>
  <span class="copy-left">&copy;</span> 1999-<span id="year"></span> Marcos Ramírez<span class="cursor-glow">_</span>
</footer>

<script>
  const yearEl = document.getElementById('year');
  if (yearEl) {
    yearEl.textContent = String(new Date().getFullYear());
  }
</script>

<style>
  footer {
    background-color: #050505;
    color: #33ff33;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 10px 20px;
    text-shadow: 0 0 5px rgba(51, 255, 51, 0.5);
  }

  .copy-left {
    display: inline-block;
    transform: scaleX(-1);
    margin-right: 5px;
  }

  .blink {
    animation: blink 1s step-end infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  @keyframes cursor-glow {
    0%, 100% {
      text-shadow: 0 0 5px #33ff33, 0 0 10px #33ff33;
    }
    50% {
      text-shadow: 0 0 10px #33ff33, 0 0 20px #33ff33, 0 0 30px #33ff33;
    }
  }

  .cursor-glow {
    animation: cursor-glow 1.5s ease-in-out infinite;
    display: inline;
  }
</style>