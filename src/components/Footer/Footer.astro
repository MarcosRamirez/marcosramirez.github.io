---

<footer>
  <span class="copy-left">&copy;</span> 1999-<span id="year"></span> &nbsp;Marcos Ramírez<span class="blink">_</span>
</footer>

<script>
  const yearEl = document.getElementById('year');
  if (yearEl) {
    yearEl.textContent = String(new Date().getFullYear());
  }
</script>

<style>
  footer {
    background-color: #0a0a0a;
    color: #33ff33;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 10px 20px;
  }

  .copy-left {
    display: inline-block;
    transform: scaleX(-1);
    margin-right: 5px;
  }

  .blink {
    animation: blink 1s step-end infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
</style>